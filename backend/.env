# Server
PORT=5000
NODE_ENV=production

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/secure-deletion

# Redis
REDIS_URL=redis://username:password@redis-server:6379

# Firebase Admin
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKey\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# JWT
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRE=7d

# Encryption
ENCRYPTION_KEY=your-256-bit-encryption-key
SALT_ROUNDS=12

# API
API_URL=https://your-backend-url.com
FRONTEND_URL=https://your-frontend-url.com

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
